static constexpr const auto cUnicodeDataSize = sizeof(cUnicodeData) / sizeof(cUnicodeData[0]);

export [[nodiscard]] constexpr inline auto GetUnicodeCategory(uint32_t code_point) -> EUnicodeCategory {
	int left{0};
	int right{cUnicodeDataSize - 1};

	while (left <= right) {
		auto mid = left + (right - left) / 2;
		const auto& range = cUnicodeData[mid];

		if (code_point < range.start) {
			right = mid - 1;
		}
		else if (code_point > range.end) {
			left = mid + 1;
		}
		else {
			return range.category;
		}
	}

	return EUnicodeCategory::UNKNOWN;
}

export [[nodiscard]] constexpr inline auto IsAlpha(uint32_t code_point) -> bool {
	using enum EUnicodeCategory;
	switch (GetUnicodeCategory(code_point)) {
	case LU:
	case LL:
	case LT:
	case LM:
	case LO:
		return true;
	default:
		return false;
	}
}

export [[nodiscard]] constexpr inline auto IsDigit(uint32_t code_point) -> bool {
	return (GetUnicodeCategory(code_point) == EUnicodeCategory::ND);
}

export inline bool IsSpace(uint32_t code_point) {
	using enum EUnicodeCategory;
	switch (GetUnicodeCategory(code_point)) {
	case ZS:
	case ZL:
	case ZP:
		return true;
	default:
		return false;
	}
}

export [[nodiscard]] constexpr inline auto IsPunctuation(uint32_t code_point) -> bool {
	using enum EUnicodeCategory;
	switch (GetUnicodeCategory(code_point)) {
	case PC:
	case PD:
	case PS:
	case PE:
	case PI:
	case PF:
	case PO:
		return true;
	default:
		return false;
	}
}
